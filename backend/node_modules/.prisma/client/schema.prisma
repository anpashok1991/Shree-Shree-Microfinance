generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String
  role          String    @default("STAFF")
  status        String    @default("ACTIVE")
  isLocked      Boolean   @default(false)
  loginAttempts Int       @default(0)
  lastLogin     DateTime?
  createdById   String?
  createdBy     User?     @relation("UserCreatedBy", fields: [createdById], references: [id])
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedById   String?
  deletedBy     User?     @relation("UserDeletedBy", fields: [deletedById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  areas             UserArea[]
  customers         Customer[]      @relation("CreatedByUser")
  assignedCustomers Customer[]      @relation("AssignedStaff")
  loanApprovals     Loan[]          @relation("LoanApprovedBy")
  loanCreated       Loan[]          @relation("LoanCreatedBy")
  loanDeleted       Loan[]          @relation("LoanDeletedBy")
  collections       Collection[]
  collectionDeleted Collection[]    @relation("CollectionDeletedBy")
  auditLogs         AuditLog[]
  notifications     Notification[]
  receipts          Receipt[]
  settings          SystemSetting[]
  expenseEntries    Expense[]       @relation("ExpenseRecordedBy")
  expenseDeleted    Expense[]       @relation("ExpenseDeletedBy")
  createdUsers      User[]          @relation("UserCreatedBy")
  usersDeleted      User[]          @relation("UserDeletedBy")
  customerDeleted   Customer[]      @relation("CustomerDeletedBy")
  areaDeleted       Area[]          @relation("AreaDeletedBy")
  borrowerProfile   Customer?       @relation("BorrowerUser")

  @@map("users")
}

model Area {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?     @relation("AreaDeletedBy", fields: [deletedById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users     UserArea[]
  customers Customer[]

  @@map("areas")
}

model UserArea {
  userId String
  areaId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  area   Area   @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([userId, areaId])
  @@map("user_areas")
}

model Customer {
  id               String    @id @default(cuid())
  customerId       String    @unique
  photo            String?
  name             String
  fatherName       String
  mobile           String
  alternateMobile  String?
  aadhaarNumber    String    @unique
  panNumber        String?
  address          String
  village          String
  district         String
  state            String
  pinCode          String
  occupation       String
  monthlyIncome    Float?
  guarantorName    String?
  guarantorMobile  String?
  guarantorAadhaar String?
  aadhaarCopy      String?
  panCopy          String?
  photoUpload      String?
  documents        String?
  userId           String?   @unique
  user             User?     @relation("BorrowerUser", fields: [userId], references: [id])
  status           String    @default("PENDING")
  createdById      String
  createdBy        User      @relation("CreatedByUser", fields: [createdById], references: [id])
  areaId           String
  area             Area      @relation(fields: [areaId], references: [id])
  assignedStaffId  String?
  assignedStaff    User?     @relation("AssignedStaff", fields: [assignedStaffId], references: [id])
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?
  deletedById      String?
  deletedBy        User?     @relation("CustomerDeletedBy", fields: [deletedById], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  loans       Loan[]
  collections Collection[]

  @@index([name, mobile, aadhaarNumber])
  @@map("customers")
}

model Loan {
  id                String    @id @default(cuid())
  loanNumber        String    @unique
  renewalNumber     String?
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id])
  amount            Float
  fileCharge        Float
  fileChargePercent Float     @default(3)
  disbursedAmount   Float
  dailyCollection   Float
  totalRecovery     Float
  tenure            Int       @default(100)
  interestRate      Float     @default(20)
  status            String    @default("PENDING_APPROVAL")
  approvedById      String?
  approvedBy        User?     @relation("LoanApprovedBy", fields: [approvedById], references: [id])
  approvedAt        DateTime?
  rejectionReason   String?
  returnReason      String?
  parentLoanId      String?
  parentLoan        Loan?     @relation("RenewedLoans", fields: [parentLoanId], references: [id])
  renewedLoans      Loan[]    @relation("RenewedLoans")
  renewalCharge     Float?
  totalPaid         Float     @default(0)
  outstanding       Float     @default(0)
  startDate         DateTime?
  endDate           DateTime?
  closedAt          DateTime?
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?
  deletedById       String?
  deletedBy         User?     @relation("LoanDeletedBy", fields: [deletedById], references: [id])
  createdById       String
  createdBy         User      @relation("LoanCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  collections Collection[]
  receipts    Receipt[]

  @@index([loanNumber, customerId, status])
  @@map("loans")
}

model Collection {
  id             String    @id @default(cuid())
  collectionNo   String    @unique
  loanId         String
  loan           Loan      @relation(fields: [loanId], references: [id])
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  amount         Float
  status         String    @default("PAID")
  collectedById  String
  collectedBy    User      @relation(fields: [collectedById], references: [id])
  collectionDate DateTime  @default(now())
  remarks        String?
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  deletedById    String?
  deletedBy      User?     @relation("CollectionDeletedBy", fields: [deletedById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  receipt Receipt?

  @@index([loanId, customerId, collectedById, collectionDate])
  @@map("collections")
}

model Receipt {
  id            String     @id @default(cuid())
  receiptNo     String     @unique
  collectionId  String     @unique
  collection    Collection @relation(fields: [collectionId], references: [id])
  loanId        String
  loan          Loan       @relation(fields: [loanId], references: [id])
  customerId    String
  customerName  String
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  generatedById String
  generatedBy   User       @relation(fields: [generatedById], references: [id])
  printCount    Int        @default(0)
  whatsappSent  Boolean    @default(false)
  smsSent       Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([receiptNo, loanId, customerId])
  @@map("receipts")
}

model Enquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  isRead    Boolean  @default(false)
  response  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("enquiries")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  oldValue  String?
  newValue  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, entity, action, createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedById String?
  updatedBy   User?    @relation(fields: [updatedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  message     String
  isRead      Boolean  @default(false)
  type        String   @default("INFO")
  referenceId String?
  createdAt   DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model Expense {
  id           String    @id @default(cuid())
  description  String
  amount       Float
  category     String
  date         DateTime  @default(now())
  recordedById String
  recordedBy   User      @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])
  remarks      String?
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deletedById  String?
  deletedBy    User?     @relation("ExpenseDeletedBy", fields: [deletedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("expenses")
}
