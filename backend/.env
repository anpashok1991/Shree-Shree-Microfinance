# Server
PORT=5000
NODE_ENV=development

# Database - Change DATABASE_URL to switch databases
# SQLite (Development)
DATABASE_URL="file:./dev.db"
# PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/shreeshree?schema=public"
# SQL Server
# DATABASE_URL="sqlserver://localhost:1433;database=shreeshree;user=sa;password=password;trustServerCertificate=true"
# MySQL
# DATABASE_URL="mysql://user:password@localhost:3306/shreeshree"

# JWT
JWT_SECRET="shree-shree-microfinance-jwt-secret-change-in-production"
